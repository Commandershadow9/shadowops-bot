{
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "description": "Zusammenfassung der Analyst-Session"
    },
    "topics_investigated": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Liste der untersuchten Themen"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "fix_type": {
            "type": "string",
            "enum": ["issue_needed", "needs_decision", "info_only"]
          },
          "affected_project": { "type": "string" },
          "affected_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "auto_fix_details": { "type": "string" },
          "rollback_command": { "type": "string" },
          "issue_title": { "type": "string" },
          "issue_body": { "type": "string" }
        },
        "required": ["severity", "category", "title", "description", "fix_type", "affected_project"],
        "additionalProperties": false
      },
      "description": "Erkenntnisse und Findings der Session"
    },
    "knowledge_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "subject": { "type": "string" },
          "content": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["category", "subject", "content", "confidence"],
        "additionalProperties": false
      },
      "description": "Wissensaktualisierungen aus der Analyse"
    },
    "health_check_passed": {
      "type": "boolean",
      "description": "Ob der Gesundheitscheck bestanden wurde"
    },
    "next_priority": {
      "type": "string",
      "description": "Naechste Prioritaet fuer zukuenftige Sessions"
    },
    "areas_checked": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Liste der geprueften Bereiche (z.B. firewall, docker, ssh, permissions, packages, logs, network)"
    },
    "areas_deferred": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bereiche die uebersprungen wurden (mit Begruendung in next_priority)"
    },
    "finding_assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "integer", "description": "ID eines in dieser Session erstellten Findings" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "discovery_method": { "type": "string", "description": "Wie gefunden: trivy, crowdsec, fail2ban, manual_review, log_analysis, ss_check, config_review" },
          "is_actionable": { "type": "boolean" },
          "is_false_positive": { "type": "boolean" },
          "false_positive_reason": { "type": "string" }
        },
        "required": ["finding_id", "confidence", "discovery_method", "is_actionable"],
        "additionalProperties": false
      },
      "description": "Selbstbewertung der eigenen Findings"
    }
  },
  "required": ["summary", "topics_investigated", "findings", "knowledge_updates", "health_check_passed", "next_priority", "areas_checked", "areas_deferred", "finding_assessments"],
  "additionalProperties": false
}
