{
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "tldr": { "type": "string" },
    "summary": { "type": "string" },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["feature", "fix", "improvement", "breaking", "docs"] },
          "description": { "type": "string" },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["type", "description"],
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "commits": { "type": "integer" },
        "files_changed": { "type": "integer" },
        "lines_added": { "type": "integer" },
        "lines_removed": { "type": "integer" },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests_passed": { "type": "integer" },
        "tests_total": { "type": "integer" },
        "coverage_percent": { "type": "number" }
      },
      "required": ["commits", "files_changed", "lines_added", "lines_removed", "contributors"],
      "additionalProperties": false
    },
    "version": { "type": "string" },
    "language": { "type": "string", "enum": ["de", "en"] },
    "web_url": { "type": "string" }
  },
  "required": ["title", "tldr", "summary", "changes", "stats", "version", "language"],
  "additionalProperties": false
}
