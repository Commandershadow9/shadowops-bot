{
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "tldr": { "type": "string" },
    "summary": { "type": "string" },
    "discord_highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "web_content": { "type": "string" },
    "breaking_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["feature", "content", "gameplay", "design", "performance", "multiplayer", "fix", "breaking", "infrastructure", "improvement", "docs", "security"] },
          "description": { "type": "string" },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          },
          "author": { "type": "string", "description": "Name des Autors (z.B. 'Shadow', 'Mapu'). Leer-String wenn unklar." }
        },
        "required": ["type", "description", "details"],
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "commits": { "type": "integer" },
        "files_changed": { "type": "integer" },
        "lines_added": { "type": "integer" },
        "lines_removed": { "type": "integer" },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests_passed": { "type": ["integer", "null"] },
        "tests_total": { "type": ["integer", "null"] },
        "coverage_percent": { "type": ["number", "null"] }
      },
      "required": ["commits", "files_changed", "lines_added", "lines_removed", "contributors", "tests_passed", "tests_total", "coverage_percent"],
      "additionalProperties": false
    },
    "version": { "type": "string" },
    "language": { "type": "string", "enum": ["de", "en"] },
    "seo_keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "5-10 spezifische, suchrelevante Keywords für SEO"
    },
    "seo_category": {
      "type": "string",
      "enum": ["feature", "security", "performance", "bugfix", "maintenance"],
      "description": "Hauptkategorie dieses Releases"
    },
    "discord_teaser": {
      "type": "string",
      "description": "Kurzer Discord-Teaser mit Cliffhanger (max 1000 Zeichen). Leer-String wenn kein Teaser gewuenscht."
    }
  },
  "required": ["title", "tldr", "summary", "discord_highlights", "web_content", "breaking_changes", "changes", "stats", "version", "language", "seo_keywords", "seo_category", "discord_teaser"],
  "additionalProperties": false
}
