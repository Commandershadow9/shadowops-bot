{
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "tldr": { "type": "string" },
    "summary": { "type": "string" },
    "discord_highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "web_content": { "type": "string" },
    "breaking_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["feature", "fix", "improvement", "breaking", "docs"] },
          "description": { "type": "string" },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["type", "description", "details"],
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "commits": { "type": "integer" },
        "files_changed": { "type": "integer" },
        "lines_added": { "type": "integer" },
        "lines_removed": { "type": "integer" },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests_passed": { "type": ["integer", "null"] },
        "tests_total": { "type": ["integer", "null"] },
        "coverage_percent": { "type": ["number", "null"] }
      },
      "required": ["commits", "files_changed", "lines_added", "lines_removed", "contributors", "tests_passed", "tests_total", "coverage_percent"],
      "additionalProperties": false
    },
    "version": { "type": "string" },
    "language": { "type": "string", "enum": ["de", "en"] }
  },
  "required": ["title", "tldr", "summary", "discord_highlights", "web_content", "breaking_changes", "changes", "stats", "version", "language"],
  "additionalProperties": false
}
